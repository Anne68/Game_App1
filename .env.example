# ---------- SECURITY ----------
SECRET_KEY=change_me_to_at_least_32_chars_long________________
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- DATABASE ----------
DB_URL=mysql+pymysql://USER:PASS@HOST:3306/games?charset=utf8mb4

# ---------- API ----------
